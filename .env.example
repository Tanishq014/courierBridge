# Copy this file to .env for local development.

# Local SQLite database URL.
COURIERBRIDGE_DATABASE_URL=sqlite:///./courierbridge.db

# Production Supabase/Postgres example. Use this on Render, not normally in local .env.
# COURIERBRIDGE_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Password-only access gate.
# Leave blank locally. On Render, set REQUIRE_AUTH=true plus password and secret.
COURIERBRIDGE_REQUIRE_AUTH=false
COURIERBRIDGE_ACCESS_PASSWORD=
COURIERBRIDGE_SECRET_KEY=

# Optional AI tracking assistant.
# Leave blank to use local rule-based analysis only.
GEMINI_API_KEY=
# Override if needed. Default in code is gemini-3.1-flash-lite.
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional 17TRACK browser endpoint adapter for brand-specific tracking.
# FedEx brand code is known from local captured request: 101393.
# UPS is configured through 17TRACK by default. NZ Post uses the direct adapter below unless you configure a 17TRACK code.
SEVENTEEN_TRACK_ENDPOINT=https://t.17track.net/track/restapi
SEVENTEEN_TRACK_FC_FEDEX=101393
SEVENTEEN_TRACK_FC_UPS=100398
SEVENTEEN_TRACK_FC_DPD=0
SEVENTEEN_TRACK_FC_NZPOST=
# Optional if 17TRACK requires browser session/signature from a captured request.
SEVENTEEN_TRACK_COOKIE=
SEVENTEEN_TRACK_GUID=
SEVENTEEN_TRACK_SIGN=
SEVENTEEN_TRACK_TIMEZONE_OFFSET=-330
# Optional per-carrier overrides when the captured 17TRACK request uses a carrier-specific signature.
SEVENTEEN_TRACK_COOKIE_UPS=
SEVENTEEN_TRACK_GUID_UPS=
SEVENTEEN_TRACK_SIGN_UPS=
SEVENTEEN_TRACK_TIMEZONE_OFFSET_UPS=
SEVENTEEN_TRACK_COOKIE_DPD=
SEVENTEEN_TRACK_GUID_DPD=
SEVENTEEN_TRACK_SIGN_DPD=
SEVENTEEN_TRACK_TIMEZONE_OFFSET_DPD=-480
# Alternative JSON map, for example: {"ups":123,"nzpost":456}
SEVENTEEN_TRACK_CARRIER_CODES=

# Optional direct carrier adapters.
# NZ Post worked from the captured request without cookies.
NZPOST_TRACK_ENDPOINT=https://tools.nzpost.co.nz/tracking/api/parceltrack/parcels

# QuickShip public tracking API.
QUICKSHIP_TRACK_ENDPOINT=https://qsapi.quickshipnow.com/public/track
