# Copy this file to .env for local development.

# Local SQLite database URL.
COURIERBRIDGE_DATABASE_URL=sqlite:///./courierbridge.db

# Production Supabase/Postgres example. Use this on Render, not normally in local .env.
# COURIERBRIDGE_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Password-only access gate.
# Leave blank locally. On Render, set REQUIRE_AUTH=true plus password and secret.
COURIERBRIDGE_REQUIRE_AUTH=false
COURIERBRIDGE_ACCESS_PASSWORD=
COURIERBRIDGE_SECRET_KEY=

# Optional AI tracking assistant.
# Leave blank to use local rule-based analysis only.
GEMINI_API_KEY=
# Override if needed. Default in code is gemini-3.1-flash-lite.
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional 17TRACK official API for FedEx/UPS/DHL/DPD.
# Put the real key in .env or Render env vars; do not commit it.
SEVENTEEN_TRACK_API_KEY=
SEVENTEEN_TRACK_REGISTER_ENDPOINT=https://api.17track.net/track/v2.2/register
SEVENTEEN_TRACK_GETINFO_ENDPOINT=https://api.17track.net/track/v2.2/gettrackinfo
SEVENTEEN_TRACK_FC_FEDEX=101393
SEVENTEEN_TRACK_FC_UPS=100398
SEVENTEEN_TRACK_FC_DHL=100001
SEVENTEEN_TRACK_FC_DPD=100010
# Alternative JSON map, for example: {"ups":100398,"dpd":100010}
SEVENTEEN_TRACK_CARRIER_CODES=

# Optional direct carrier adapters.
# NZ Post worked from the captured request without cookies.
NZPOST_TRACK_ENDPOINT=https://tools.nzpost.co.nz/tracking/api/parceltrack/parcels

# QuickShip public tracking API.
QUICKSHIP_TRACK_ENDPOINT=https://qsapi.quickshipnow.com/public/track
